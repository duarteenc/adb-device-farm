# Environment Variables Example
# Copy this file to .env and configure as needed

# Development mode
NODE_ENV=development

# ADB Configuration
# ADB_PATH=adb  # Path to ADB executable (default: 'adb' from PATH)

# Device Discovery
# AUTO_REFRESH_INTERVAL=5000  # Device refresh interval in milliseconds

# Logging
# LOG_LEVEL=info  # Log level: info, warn, error
# MAX_LOG_ENTRIES=1000  # Maximum log entries to keep in memory
